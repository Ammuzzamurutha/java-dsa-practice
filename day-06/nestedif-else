import java.util.*;
public class basics1 {
    public static void main(String[] args) {
         //nested if else
    boolean isstudent=false;
    boolean issenior=true;
    double price=9.9;
    if(isstudent){
        if(issenior){
            System.out.println("you are a student get 10% discount");
            System.out.println("you are a senior get 20% discount");
            price=price*0.7;
        }
        else{
            System.out.println("you are a student get 10% discount");
            price=price*0.9;
        }
    }
    else{
        if(issenior){
            System.out.println("you are a senior get 20% discount");
            price=price*0.8;
        }
        else{
            System.out.println("you are not a student and not a senior, no discount");
            price*=1;
        }
    }
    System.out.printf("the price of a ticket is Rs.%.2f", price);
 
    }
}
